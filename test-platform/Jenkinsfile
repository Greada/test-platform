// ============================================================================
// Jenkinsfile — 全功能测试平台 CI/CD Pipeline
// 运行环境：Jenkins 容器（挂载 docker.sock） + Docker Compose
// 目标服务器：192.168.0.10
// 仓库地址：https://gitee.com/greada/test-platform.git
// 注意事项：
//   1. Jenkins 容器需挂载 /var/run/docker.sock 以调用宿主机 Docker
//   2. 项目代码在仓库的 test-platform/ 子目录下
//   3. 只需安装 Git 和 Pipeline 两个插件即可运行
// ============================================================================

pipeline {
    agent any

    environment {
        // 项目代码在仓库子目录 test-platform/ 下
        // WORKSPACE 是 Jenkins checkout 的根目录（即仓库根目录）
        PROJECT_DIR = "${WORKSPACE}/test-platform"

    }

    stages {

        // ====================================================================
        // 1. 代码检出 — 从 Gitee 拉取最新代码
        //    仓库公开，不需要填写凭证（Credentials）
        // ====================================================================
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ====================================================================
        // 2. 构建 Docker 镜像 — 利用 Dockerfile 多阶段构建
        //    backend/Dockerfile 内部完成 Maven 编译 + JRE 打包
        //    frontend/Dockerfile 内部完成 npm ci + npm run build + Nginx
        //    不需要在 Jenkins 中单独做编译，减少依赖
        // ====================================================================
        stage('Docker Build') {
            steps {
                sh '''
                    echo "===== 构建后端镜像 ====="
                    docker compose -f ${PROJECT_DIR}/docker-compose.yml build backend

                    echo "===== 构建前端镜像 ====="
                    docker compose -f ${PROJECT_DIR}/docker-compose.yml build frontend
                '''
            }
        }

        // ====================================================================
        // 3. 部署 — 用新镜像替换运行中的容器
        //    只重建 backend 和 frontend，不碰 MySQL 服务
        //    compose 会检测到同名的 tp-backend/tp-frontend 容器并自动替换
        // ====================================================================
        stage('Deploy') {
            steps {
                sh '''
                    echo "===== 更新容器 ====="
                    docker compose -f ${PROJECT_DIR}/docker-compose.yml up -d backend frontend

                    echo "===== 清理旧镜像 ====="
                    docker image prune -f
                '''
            }
        }

        // ====================================================================
        // 4. 验证 — 检查容器状态 + API 可用性
        //    登录 API 返回 200 代表后端正常工作
        //    前端返回 200/302 代表 Nginx 正常分发
        // ====================================================================
        stage('Verify') {
            steps {
                sh '''
                    echo "===== 容器状态 ====="
                    docker ps --filter "name=tp-" \\
                        --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}"

                    echo "===== 等待服务启动 ====="
                    sleep 15

                    echo "===== 测试登录 API ====="
                    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \\
                        -X POST http://localhost:8080/api/auth/login \\
                        -H 'Content-Type: application/json' \\
                        -d '{"username":"admin","password":"admin123"}')

                    if [ "$HTTP_CODE" = "200" ]; then
                        echo "✅ 后端 API 正常，HTTP 状态码: $HTTP_CODE"
                    else
                        echo "❌ 后端 API 异常，HTTP 状态码: $HTTP_CODE"
                        exit 1
                    fi

                    echo "===== 测试前端 ====="
                    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \\
                        http://localhost:80/)

                    if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "302" ]; then
                        echo "✅ 前端正常，HTTP 状态码: $HTTP_CODE"
                    else
                        echo "❌ 前端异常，HTTP 状态码: $HTTP_CODE"
                        exit 1
                    fi

                    echo ""
                    echo "✅✅✅ 部署全部通过 ✅✅✅"
                '''
            }
        }
    }

    // ========================================================================
    // 构建后处理
    // ========================================================================
    post {
        // 无论成功还是失败，都打印当前容器列表
        always {
            sh '''
                echo "===== 最终容器状态 ====="
                docker ps --filter "name=tp-" --format "table {{.Names}}\\t{{.Status}}"
            '''
        }

        // 部署失败时输出后端日志最后 50 行，方便排查
        failure {
            sh '''
                echo "===== 后端最近日志 ====="
                docker logs tp-backend --tail 50 2>&1 || echo "无日志"
            '''
        }

        success {
            echo "✅ 部署成功完成"
        }

        // 清理工作空间，释放 Jenkins 磁盘空间
        cleanup {
            deleteDir()
        }
    }
}
