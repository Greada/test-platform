// ============================================================================
// Jenkinsfile — 全功能测试平台 CI/CD Pipeline
// 运行环境：Jenkins 容器（挂载 docker.sock） + Docker Compose
// 目标服务器：192.168.0.10
// 仓库地址：https://gitee.com/greada/test-platform.git
// 注意事项：
//   1. Jenkins 容器需挂载 /var/run/docker.sock 以调用宿主机 Docker
//   2. 项目代码在仓库的 test-platform/ 子目录下
//   3. 只需安装 Git 和 Pipeline 两个插件即可运行
// ============================================================================

pipeline {
    agent any

    stages {

        // ====================================================================
        // 1. 代码检出 — 从 Gitee 拉取最新代码
        // ====================================================================
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ====================================================================
        // 2. 运行单元测试 — 测试失败则阻断部署
        //     直接在 Jenkins 容器内安装 Maven 运行，避免 Docker
        //     跨容器卷挂载路径不一致的问题。
        // ====================================================================
        stage('Test') {
            steps {
                    sh '''
                        echo "===== 运行单元测试 ====="
                        docker run --rm \\
                            --volumes-from "$(hostname)" \\
                            -w "$WORKSPACE/test-platform" \\
                            -v "maven-repo:/root/.m2" \\
                            --network host \\
                            maven:3.9-eclipse-temurin-17 \\
                            mvn test -f backend/pom.xml -B -s backend/settings.xml
                    '''
            }
            post {
                always {
                    junit 'test-platform/backend/target/surefire-reports/*.xml'
                }
            }
        }

        // ====================================================================
        // 3. 构建 Docker 镜像
        //    dir() 切换到项目目录后，docker compose 会自动找到
        //    docker-compose.yml；不需要 -f 参数
        // ====================================================================
        stage('Docker Build') {
            steps {
                dir("${WORKSPACE}/test-platform") {
                    sh '''
                        echo "===== 构建后端镜像 ====="
                        docker compose build backend

                        echo "===== 构建前端镜像 ====="
                        docker compose build frontend
                    '''
                }
            }
        }

        // ====================================================================
        // 4. 部署 — 用新镜像替换运行中的容器
        // ====================================================================
        stage('Deploy') {
            steps {
                dir("${WORKSPACE}/test-platform") {
                    sh '''
                        echo "===== 更新容器 ====="
                        docker compose up -d backend frontend

                        echo "===== 清理旧镜像 ====="
                        docker image prune -f
                    '''
                }
            }
        }

        // ====================================================================
        // 5. 验证 — 检查容器状态 + API 可用性
        //    注意：Jenkins 容器内 localhost 不等于宿主机 localhost，
        //    所以用 docker exec 从容器内部测试，或用 docker run --network host
        // ====================================================================
        stage('Verify') {
            steps {
                sh '''
                    echo "===== 容器状态 ====="
                    docker ps --filter "name=tp-" \\
                        --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}"

                    echo "===== 等待服务启动 ====="
                    sleep 15

                    echo "===== 测试登录 API ====="
                    HTTP_CODE=$(docker run --rm --network host curlimages/curl:latest \\
                        -s -o /dev/null -w "%{http_code}" \\
                        -X POST http://localhost:8080/api/auth/login \\
                        -H 'Content-Type: application/json' \\
                        -d '{"username":"admin","password":"admin123"}')

                    if [ "$HTTP_CODE" = "200" ]; then
                        echo "✅ 后端 API 正常，HTTP 状态码: $HTTP_CODE"
                    else
                        echo "❌ 后端 API 异常，HTTP 状态码: $HTTP_CODE"
                        exit 1
                    fi

                    echo "===== 测试前端 ====="
                    HTTP_CODE=$(docker run --rm --network host curlimages/curl:latest \\
                        -s -o /dev/null -w "%{http_code}" \\
                        http://localhost/)

                    if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "302" ]; then
                        echo "✅ 前端正常，HTTP 状态码: $HTTP_CODE"
                    else
                        echo "❌ 前端异常，HTTP 状态码: $HTTP_CODE"
                        exit 1
                    fi

                    echo ""
                    echo "✅✅✅ 部署全部通过 ✅✅✅"
                '''
            }
        }
    }

    // ========================================================================
    // 构建后处理
    // ========================================================================
    post {
        always {
            sh '''
                echo "===== 最终容器状态 ====="
                docker ps --filter "name=tp-" --format "table {{.Names}}\\t{{.Status}}"
            '''
        }

        failure {
            sh '''
                echo "===== 后端最近日志 ====="
                docker logs tp-backend --tail 50 2>&1 || echo "无日志"
            '''
        }

        success {
            echo "✅ 部署成功完成"
        }

        cleanup {
            deleteDir()
        }
    }
}
